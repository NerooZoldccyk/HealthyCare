<div class="alert alert-primary shadow-sm">

    <div class="d-flex justify-content-between align-items-center">

        <div>

            <h3 class="mb-2">

                <span id="greeting"></span>,

                <b><%= session.user.name %></b>

                👋

            </h3>

            <p class="mb-0">

                Anda login sebagai

                <span class="badge bg-success">

                    <%= session.user.role.toUpperCase() %>

                </span>

            </p>

        </div>

        <div class="text-end">

            <h6 id="tanggal"></h6>

            <small id="jam"></small>

        </div>

    </div>

</div>

<div class="row">

    <div class="col-md-4 mb-3">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <i class="bi bi-hospital fs-1 text-primary"></i>

                <h5 class="mt-3">

                    Total Doctor

                </h5>

                <h1 class="text-primary">

                    <%= totalDoctors %>

                </h1>

            </div>

        </div>

    </div>

    <div class="col-md-4 mb-3">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <i class="bi bi-person-fill fs-1 text-success"></i>

                <h5 class="mt-3">

                    Total Patient

                </h5>

                <h1 class="text-success">

                    <%= totalPatients %>

                </h1>

            </div>

        </div>

    </div>

    <div class="col-md-4 mb-3">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <i class="bi bi-calendar-check fs-1 text-danger"></i>

                <h5 class="mt-3">

                    Total Reservation

                </h5>

                <h1 class="text-danger">

                    <%= totalReservations %>

                </h1>

            </div>

        </div>

    </div>

</div>

<div class="card shadow mt-4">

    <div class="card-body">

        <h4>

            Smart Health Management System

        </h4>

        <hr>

        <p style="text-align:justify;">

            <b>HealthyCare</b> merupakan aplikasi berbasis web yang dikembangkan untuk membantu proses pengelolaan layanan kesehatan secara terintegrasi. Sistem ini menyediakan fasilitas manajemen data dokter, pasien, dan reservasi sehingga proses pencatatan, pengelolaan informasi, serta pelayanan dapat dilakukan secara lebih efektif, efisien, dan terstruktur.

        </p>

        <p style="text-align:justify;">

            Aplikasi ini menerapkan sistem autentikasi menggunakan <b>Session Login</b> serta mekanisme <b>Role Based Access Control (RBAC)</b>. Administrator memiliki hak penuh untuk mengelola seluruh data, sedangkan pengguna (User) hanya dapat mengakses fitur sesuai hak akses yang diberikan. Dengan demikian keamanan data serta pengelolaan informasi dapat berjalan dengan lebih baik.

        </p>

    </div>

</div>

<script>

function updateDateTime(){

    const now = new Date();

    const hour = now.getHours();

    let greeting = "";

    if(hour >= 5 && hour < 11){

        greeting = "🌅 Selamat Pagi";

    }else if(hour >= 11 && hour < 15){

        greeting = "☀️ Selamat Siang";

    }else if(hour >= 15 && hour < 18){

        greeting = "🌇 Selamat Sore";

    }else{

        greeting = "🌙 Selamat Malam";

    }

    document.getElementById("greeting").innerHTML = greeting;

    document.getElementById("tanggal").innerHTML =
    now.toLocaleDateString("id-ID",{
        weekday:"long",
        day:"numeric",
        month:"long",
        year:"numeric"
    });

    document.getElementById("jam").innerHTML =
    now.toLocaleTimeString("id-ID");

}

setInterval(updateDateTime,1000);

updateDateTime();

</script>